datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String                @id @default(uuid()) @map("_id")
  username     String                @unique
  email        String                @unique
  passwordHash String
  name         String
  startDate    String                @default("2024-01")
  currency     String                @default("USD")
  theme        String                @default("system")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  salaryEvents EmbeddedSalaryEvent[]
  compEvents   EmbeddedCompEvent[]
}

type EmbeddedSalaryEvent {
  id               String
  date             String
  salary           Float
  type             String
  title            String
  company          String
  currency         String?
  country          String?
  location         String?
  monthlyNetSalary Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

type EmbeddedCompEvent {
  id        String
  date      String
  amount    Float
  type      String
  title     String
  company   String
  currency  String?
  country   String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}
