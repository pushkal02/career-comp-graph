# Port for the Express backend server (default: 5000)
PORT=

# MongoDB Atlas connection string for Prisma.
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/<database_name>?retryWrites=true&w=majority&appName=<AppName>
DATABASE_URL=

# JWT secret key used for encoding user authentication session tokens.
# Replace this with a strong random string in production.
JWT_SECRET=

# Cache duration in milliseconds for live currency exchange rates and PPP conversion factors (default: 86400000 = 24 hours).
VITE_CACHE_DURATION_MS=
